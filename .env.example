# ============================================
# Claude Code ⇔ Slack Bridge 設定
# ============================================

# --- Slack App 設定 ---
# 1. https://api.slack.com/apps で新しいアプリを作成
# 2. Socket Mode を有効化 → App-Level Token を取得 (xapp-...)
# 3. OAuth & Permissions で Bot Token Scopes を追加:
#    - chat:write
#    - channels:history
#    - groups:history (プライベートチャンネル用)
#    - files:read
#    - files:write
# 4. Event Subscriptions を有効化し、以下を Subscribe:
#    - message.channels
#    - message.groups (プライベートチャンネル用)
# 5. Install App → Bot User OAuth Token を取得 (xoxb-...)

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# 管理者のSlackユーザーID（必須）
# アクセス制御の管理者権限に使用
# (自分のプロフィール → … → Copy member ID)
ADMIN_SLACK_USER_ID=U0123456789

# --- アクセス制御 ---
# 許可ユーザー（カンマ区切り or "*" で全許可）
# 注: 管理者は設定に関わらず常に許可されます
# SLACK_ALLOWED_USERS=U1111111111,U2222222222
# SLACK_ALLOWED_USERS=*

# 許可チャンネル（カンマ区切り or "*" で全許可）
# SLACK_ALLOWED_CHANNELS=C1111111111
# SLACK_ALLOWED_CHANNELS=*

# --- 通知設定 ---
# 起動/停止通知・インスタンス検出結果の投稿先チャンネル（任意）
# 未設定の場合、通知はログ出力のみ
# NOTIFICATION_CHANNEL=C1234567890

# --- Claude Code 設定 ---
# claude コマンドのパス (which claude で確認)
CLAUDE_CMD=claude

# デフォルトで自動承認するツール (カンマ区切り)
# 安全なツールのみ列挙。必要に応じてSlackから追加可能
DEFAULT_ALLOWED_TOOLS=Read,Write,Edit,MultiEdit,Bash(git *),TodoWrite,WebSearch,WebFetch

# ログレベル (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
